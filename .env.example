# PostgreSQL (Docker Compose: pgvector on host port 5433)
# Used by NestJS (DatabaseModule pg Pool) and `pnpm migrate`
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=know_me

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# OpenAI (embeddings only)
OPENAI_API_KEY=your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# App
PORT=3000
